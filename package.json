{
  "name": "@ziix/datepicker",
  "version": "0.2.0",
  "description": "Framework-agnostic date / time / datetime picker with configurable minute steps and resource-aware selection — fetch bookable resources from a URL, show free time per resource and pick the one a task lands on.",
  "type": "module",
  "license": "MIT",
  "author": "ziix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziixdk/datepicker.git"
  },
  "homepage": "https://github.com/ziixdk/datepicker#readme",
  "bugs": {
    "url": "https://github.com/ziixdk/datepicker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "datepicker",
    "timepicker",
    "datetime",
    "calendar",
    "resource",
    "scheduling",
    "booking"
  ],
  "main": "./dist/ziix-datepicker.js",
  "module": "./dist/ziix-datepicker.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ziix-datepicker.js"
    },
    "./styles.css": "./dist/ziix-datepicker.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "dayjs": "^1.11.21",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
